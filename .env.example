# Copy to .env on the VPS and fill in. docker-compose reads it automatically.

# Domain pointed at the VPS public IP (A record). Caddy gets HTTPS for this.
DOMAIN=garmin.example.com

# Optional: email for Let's Encrypt expiry notices.
ACME_EMAIL=you@example.com

# The single shared password for the whole app.
GARMIN_GUI_PASSWORD=change-me-to-something-strong

# Stable session signing key so logins survive restarts.
# Generate once with:  python -c "import secrets;print(secrets.token_urlsafe(32))"
GARMIN_GUI_SECRET=replace-with-generated-key
